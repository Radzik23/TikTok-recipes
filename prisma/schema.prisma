generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Tabela Użytkowników
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  
  recipes   Recipe[]
}

// Tabela Przepisów
model Recipe {
  id          String   @id @default(cuid())
  title       String
  originalUrl String   
  image       String?  
  time        String?  
  difficulty  String?  
  
  ingredients Json
  steps       Json
  
  createdAt   DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  USER
  ADMIN
}